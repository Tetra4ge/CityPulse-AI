# =============================================================================
# CityPulse AI — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# None of these are needed for Phase 0 (everything is stubbed/mocked).
# They will become required in later phases as noted.

# --- Google Cloud (Phase 1+) ---
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
BIGQUERY_DATASET=citypulse_ai

# --- Google Cloud Storage (Phase 1+) ---
GCS_BUCKET_NAME=citypulse-raw-ingestion

# --- Gemini / Vertex AI (Phase 2+) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- External APIs (Phase 1+) ---
OPENAQ_API_KEY=your-openaq-api-key
WEATHER_API_KEY=your-weather-api-key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# --- GPU Service (Phase 2+) ---
GPU_SERVICE_URL=http://localhost:8000

# --- App Config ---
NEXT_PUBLIC_APP_NAME=CityPulse AI
NEXT_PUBLIC_DEFAULT_CITY=Delhi
NEXT_PUBLIC_DEFAULT_ZONES=Zone-A,Zone-B,Zone-C,Zone-D

# --- Local Dev Database (Phase 0-1) ---
DATABASE_URL=file:./dev.db
