# =============================================================================
# CityPulse AI — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# None of these are needed for Phase 0 (everything is stubbed/mocked).
# They will become required in later phases as noted.

# --- Google Cloud (Phase 1+) ---
# Sign up: https://console.cloud.google.com (Free trial: $300 credit for 90 days)
# Service: BigQuery (free tier: 1TB queries/month, 10GB storage)
# Service: Cloud Storage (free tier: 5GB storage, 5000 ops/month)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
BIGQUERY_DATASET=citypulse_ai

# --- Google Cloud Storage (Phase 1+) ---
GCS_BUCKET_NAME=citypulse-raw-ingestion

# --- Gemini / Google AI Studio (Phase 2+) ---
# Get from: https://aistudio.google.com/apikey
# Free tier: 15 requests/minute, 1 million tokens/day
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- OpenRouter (Alternative LLM Provider) ---
# Get from: https://openrouter.ai/keys
# Pay-as-you-go pricing. Many models available including free-tier options.
# If OPENROUTER_API_KEY is set, agents will use OpenRouter instead of Gemini directly.
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# --- External APIs (Phase 1+) ---
# OpenAQ: https://docs.openaq.org — Free, requires registration
OPENAQ_API_KEY=your-openaq-api-key

# OpenWeatherMap: https://openweathermap.org/api — Free tier: 60 calls/min, 1M calls/month
WEATHER_API_KEY=your-weather-api-key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# --- GPU Service (Phase 2+) ---
# Local dev: http://localhost:8000
# Production: http://<COMPUTE-ENGINE-VM-IP>:8000
# Deploy on: Google Compute Engine with NVIDIA T4 GPU (free trial eligible)
GPU_SERVICE_URL=http://localhost:8000

# --- App Config ---
NEXT_PUBLIC_APP_NAME=CityPulse AI
NEXT_PUBLIC_DEFAULT_CITY=Delhi
NEXT_PUBLIC_DEFAULT_ZONES=Zone-A,Zone-B,Zone-C,Zone-D

# --- Local Dev Database (Phase 0-1) ---
# Only used when GOOGLE_CLOUD_PROJECT_ID is not set
DATABASE_URL=file:./dev.db
