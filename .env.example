# --- LLM API Keys ---
OPENROUTER_API_KEY="your-openrouter-key-here"
GEMINI_API_KEY="gemini_your_key_here"

# --- Turso Database ---
# Serverless SQLite database
TURSO_DATABASE_URL="libsql://your-database-url.turso.io"
